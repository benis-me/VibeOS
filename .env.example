# Backend
PORT=7720
VIBEOS_DB_PATH=./data/vibeos.db

# AI backend (provider). One of: codebuddy | claude | codex | openrouter.
# Default is claude. This is only the boot default — it can also be switched live
# in the Settings app (AI 引擎 / AI Engine). At boot, providers whose CLI isn't
# installed are skipped, falling back to an available one.
# VIBEOS_AI_PROVIDER=claude

# --- CLI providers (codebuddy / claude / codex) ---
# Each spawns a local CLI subprocess and must be installed + logged in:
#   codebuddy → reuses the `codebuddy` CLI login, or CODEBUDDY_API_KEY
#   claude    → reuses the `claude` CLI login, or ANTHROPIC_API_KEY
#   codex     → reuses the `codex` CLI login, or OPENAI_API_KEY
# CODEBUDDY_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# --- openrouter provider (HTTP via the Vercel AI SDK, OpenAI-compatible) ---
# OPENROUTER_API_KEY=sk-or-...
# Point the base URL elsewhere to reuse this for OpenAI / Together / a local LLM:
# VIBEOS_AI_BASE_URL=https://openrouter.ai/api/v1
# VIBEOS_AI_API_KEY=...        # alternative to OPENROUTER_API_KEY

# --- API providers (OpenAI / Anthropic / Gemini / Fal) ---
# Keys are normally entered in-app under Settings → Model Providers (stored in
# the local DB). These env vars are an optional fallback and take precedence:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...           # or GOOGLE_GENERATIVE_AI_API_KEY / GOOGLE_API_KEY
# FAL_KEY=...                  # for image generation via fal.ai

# Frontend dev server
VITE_WS_URL=ws://localhost:7720/ws

# Optional model overrides (substring-matched against discovered model ids)
# VIBEOS_MODEL_UI=
# VIBEOS_MODEL_FAST=

# Abort a single generation if the provider goes silent this long (hang guard, ms)
# VIBEOS_GEN_TIMEOUT_MS=180000

# Cap the current-UI HTML sent back as context per op (0 = no cap). UI generation
# is stateless — the full current UI is sent every op — so this is off by default.
# VIBEOS_SNAPSHOT_BUDGET=0

# Dev toggles
# VIBEOS_AI_STUB=1              # deterministic stub UI, no model needed
# VIBEOS_AGENTS_DISABLED=1     # disable the ambient timer agents
